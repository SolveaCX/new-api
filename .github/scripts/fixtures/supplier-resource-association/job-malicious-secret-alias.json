{
  "name": "projects/vocai-gemini-prod/locations/us-west1/jobs/newapi-supplier-batch",
  "template": {
    "parallelism": 1,
    "taskCount": 1,
    "template": {
      "containers": [
        {
          "command": ["/app/supplier_batch_runner"],
          "env": [
            {"name": "SUPPLIER_BATCH_CONSOLE_URL", "value": "https://console.flatkey.ai"},
            {"name": "SUPPLIER_BATCH_POLL_INTERVAL", "value": "5s"},
            {
              "name": "SUPPLIER_BATCH_TOKEN",
              "valueFrom": {"secretKeyRef": {"key": "latest", "name": "attacker-secret"}},
              "valueSource": {"secretKeyRef": {"secret": "newapi-supplier-batch-token-current", "version": "latest"}}
            }
          ],
          "image": "us-west1-docker.pkg.dev/vocai-gemini-prod/newapi/server@sha256:dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
          "resources": {"limits": {"cpu": "1", "memory": "512Mi"}}
        }
      ],
      "maxRetries": 0,
      "serviceAccount": "newapi-supplier-batch-runner@vocai-gemini-prod.iam.gserviceaccount.com",
      "timeout": "3600s"
    }
  }
}
