{
  "apiVersion": "run.googleapis.com/v1",
  "kind": "Job",
  "metadata": {
    "labels": {
      "cloud.googleapis.com/location": "us-west1"
    },
    "name": "newapi-supplier-batch",
    "namespace": "528088078482"
  },
  "spec": {
    "template": {
      "spec": {
        "parallelism": 1,
        "taskCount": 1,
        "template": {
          "spec": {
            "containers": [
              {
                "command": ["/app/supplier_batch_runner"],
                "env": [
                  {"name": "SUPPLIER_BATCH_CONSOLE_URL", "value": "https://console.flatkey.ai"},
                  {"name": "SUPPLIER_BATCH_POLL_INTERVAL", "value": "5s"},
                  {"name": "SUPPLIER_BATCH_TOKEN", "valueFrom": {"secretKeyRef": {"key": "latest", "name": "newapi-supplier-batch-token-current"}}}
                ],
                "image": "us-west1-docker.pkg.dev/vocai-gemini-prod/newapi/server@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
                "resources": {"limits": {"cpu": "1", "memory": "512Mi"}}
              }
            ],
            "maxRetries": 0,
            "serviceAccountName": "newapi-supplier-batch-runner@vocai-gemini-prod.iam.gserviceaccount.com",
            "timeoutSeconds": "3600"
          }
        }
      }
    }
  }
}
